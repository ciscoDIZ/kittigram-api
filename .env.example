# Copy this file to .env and fill in real values before running docker-compose.
# Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────
# Used both to initialize the Postgres container and by application services.
# (Dev compose uses POSTGRES_* aliases below; prod compose uses DB_* directly.)
DB_USER=kitties
DB_PASSWORD=change_me
DB_NAME=kitties
# Aliases for the dev docker-compose.yml which bootstraps the Postgres container.
POSTGRES_USER=kitties
POSTGRES_PASSWORD=change_me
POSTGRES_DB=kitties

# ─── MinIO ───────────────────────────────────────────────────────────
MINIO_ROOT_USER=kitties
MINIO_ROOT_PASSWORD=change_me_min16chars
MINIO_DEFAULT_BUCKETS=kitties
# Public URL through which clients download files (served via the gateway in prod).
STORAGE_PUBLIC_URL=https://your-domain.com/api/storage

# ─── SMTP ────────────────────────────────────────────────────────────
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_FROM=noreply@kitti.es
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
# REQUIRED | OPTIONAL | DISABLED
MAIL_TLS=REQUIRED

# ─── Application ─────────────────────────────────────────────────────
# Public frontend URL (used in activation email links).
FRONTEND_URL=https://your-domain.com

# CORS origin allowed by the gateway (prod only).
CORS_ORIGIN=https://your-domain.com

# ─── Security ────────────────────────────────────────────────────────
# Shared secret between user-service (gRPC server) and auth-service (gRPC client).
GRPC_INTERNAL_SECRET=change_me

# JWT keys — place privateKey.pem and publicKey.pem in ./secrets/ before
# starting docker-compose.prod.yml. The compose reads them as Docker secrets
# and mounts them at /run/secrets/privateKey.pem and /run/secrets/publicKey.pem.
