# Copy this file to .env and fill in real values before running docker-compose.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_USER=kitties
POSTGRES_PASSWORD=change_me
POSTGRES_DB=kitties

# MinIO
MINIO_ROOT_USER=kitties
MINIO_ROOT_PASSWORD=change_me_min16chars
MINIO_DEFAULT_BUCKETS=kitties

# gRPC shared secret (user-service ↔ auth-service)
GRPC_INTERNAL_SECRET=change_me

# Frontend URL (used in activation emails)
FRONTEND_URL=http://localhost:5173

# JWT keys (prod only — mount privateKey.pem and publicKey.pem as Docker/K8s secrets)
# Default mount paths: /run/secrets/privateKey.pem, /run/secrets/publicKey.pem
# Override with these vars if you mount them elsewhere:
# JWT_PRIVATE_KEY_LOCATION=/run/secrets/privateKey.pem
# JWT_PUBLIC_KEY_LOCATION=/run/secrets/publicKey.pem

# Grafana Cloud — datasource URLs en grafana.com → Connections → Data sources → (servicio) → Settings
# Instance IDs y API key en la sección Authentication de cada datasource
GRAFANA_LOKI_URL=https://<host>/loki/api/v1/push
GRAFANA_LOKI_USER=
GRAFANA_PROMETHEUS_URL=https://<host>/api/prom/push
GRAFANA_PROMETHEUS_USER=
GRAFANA_TEMPO_URL=https://<host>
GRAFANA_TEMPO_USER=
GRAFANA_API_KEY=
